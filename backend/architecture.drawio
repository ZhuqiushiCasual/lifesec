        <mxCell id="fk_digests" value="1:N&#10;user_id" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;html=1;exitX=0.7;exitY=1;entryX=0.5;entryY=0;strokeColor=#82b366;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="g_db" source="db_users" target="db_digests">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

