        </mxCell>

        <!-- OpenAI/DeepSeek client -->
        <mxCell id="ai_client" value="OpenAI AsyncClient&#10;(client.py — lru_cache 单例)&#10;base_url = api.deepseek.com&#10;model = deepseek-v4-pro&#10;temperature = 0.1&#10;response_format = json_object" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="g_ai">
