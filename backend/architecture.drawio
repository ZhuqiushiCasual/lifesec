        <mxCell id="ai_intent" value="意图识别&#10;LLM 判断:&#10;&quot;life&quot; | &quot;finance&quot;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="g_ai">
          <mxGeometry x="290" y="35" width="160" height="90" as="geometry" />
        </mxCell>

        <!-- Event Parser -->
        <mxCell id="ai_event" value="Event Parser&#10;(event_parser.py)&#10;System Prompt → 结构化 JSON:&#10;• type (dietary/sport/health/&#10;  mood/invest/event)&#10;• entities {food, activity, symptom,&#10;  mood, amount, currency, ...}&#10;• sentiment + score (0~1)&#10;• tags []&#10;▸ detect_finance_intent():&#10;  type==invest OR (amount+category)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="g_ai">
          <mxGeometry x="520" y="40" width="290" height="160" as="geometry" />
        </mxCell>

        <!-- Finance Parser -->
        <mxCell id="ai_finance" value="Finance Parser&#10;(finance_parser.py)&#10;System Prompt → 结构化 JSON:&#10;• type (expense/income/&#10;  asset/liability)&#10;• amount, currency&#10;• category (food/transport/salary/&#10;  rent/shopping/medical/&#10;  invest_*/real_estate/cash/other)&#10;• counterparty, account&#10;  (支付宝/微信/银行卡/证券账户)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="g_ai">
          <mxGeometry x="860" y="40" width="280" height="160" as="geometry" />
        </mxCell>

        <!-- Auth Service note -->
        <mxCell id="ai_auth_svc" value="Auth Service (auth.py)&#10;SHA-256 + salt 密码哈希&#10;HMAC-SHA256 签名 Token&#10;(非 JWT, 30天过期)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;dashed=1;" vertex="1" parent="g_ai">
          <mxGeometry x="60" y="135" width="200" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== GROUP: 数据库层 ==================== -->
        <mxCell id="g_db" value="④ 数据层 / MySQL  (SQLAlchemy ORM · asyncmy)" style="swimlane;fontSize=14;fontStyle=1;align=left;spacingLeft=12;startSize=28;horizontal=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="620" width="1620" height="560" as="geometry" />
        </mxCell>

        <!-- users table (center) -->
        <mxCell id="db_users" value="&lt;b style=&quot;font-size:13px&quot;&gt;👤 users&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#999&quot;&gt;用户表 — 账号信息&lt;/span&gt;&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;PK&lt;/b&gt; id (UUID)&lt;br&gt;email (UNIQUE)&lt;br&gt;name&lt;br&gt;hashed_password (SHA-256)&lt;br&gt;preferences (JSON)&lt;br&gt;is_active (bool)&lt;br&gt;created_at&lt;br&gt;updated_at&lt;/div&gt;" style="verticalAlign=top;align=center;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="g_db">
          <mxGeometry x="680" y="50" width="220" height="180" as="geometry" />
        </mxCell>

        <!-- events table -->
        <mxCell id="db_events" value="&lt;b style=&quot;font-size:13px&quot;&gt;📋 events&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#999&quot;&gt;事件记录表 — 生活事件&lt;/span&gt;&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;PK&lt;/b&gt; id (UUID)&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id → users.id&lt;br&gt;type (health/dietary/work/&lt;br&gt;&amp;nbsp;&amp;nbsp;social/mood/sport/invest/event)&lt;br&gt;content (Text — 原文)&lt;br&gt;entities (JSON — AI抽取实体)&lt;br&gt;sentiment (pos/neutral/neg)&lt;br&gt;sentiment_score (Float 0~1)&lt;br&gt;tags (JSON array)&lt;br&gt;voice_source (bool)&lt;br&gt;recorded_at / created_at&lt;/div&gt;" style="verticalAlign=top;align=center;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="g_db">
          <mxGeometry x="60" y="290" width="240" height="240" as="geometry" />
        </mxCell>

        <!-- finance_txns table -->
        <mxCell id="db_finance" value="&lt;b style=&quot;font-size:13px&quot;&gt;💰 finance_txns&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#999&quot;&gt;财务记录表 — 收支明细&lt;/span&gt;&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;PK&lt;/b&gt; id (UUID)&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id → users.id&lt;br&gt;type (income/expense/&lt;br&gt;&amp;nbsp;&amp;nbsp;asset/liability)&lt;br&gt;amount (Numeric 15,2)&lt;br&gt;currency (CNY 默认)&lt;br&gt;category (food/transport/salary/&lt;br&gt;&amp;nbsp;&amp;nbsp;rent/shopping/medical/invest_*/...)&lt;br&gt;counterparty (交易对手)&lt;br&gt;account (支付宝/微信/银行卡/...)&lt;br&gt;note / voice_source / recorded_at&lt;/div&gt;" style="verticalAlign=top;align=center;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="g_db">
          <mxGeometry x="380" y="290" width="240" height="240" as="geometry" />
        </mxCell>

        <!-- insights table -->
        <mxCell id="db_insights" value="&lt;b style=&quot;font-size:13px&quot;&gt;💡 insights&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#999&quot;&gt;信息洞察表 — 知识/摘要&lt;/span&gt;&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;PK&lt;/b&gt; id (UUID)&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id → users.id&lt;br&gt;title (标题)&lt;br&gt;summary (核心摘要)&lt;br&gt;impact (影响分析)&lt;br&gt;category (tech/finance/&lt;br&gt;&amp;nbsp;&amp;nbsp;health/career)&lt;br&gt;topics (JSON array)&lt;br&gt;importance (1~5)&lt;br&gt;source_url / source_name&lt;br&gt;published_at / created_at&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#b85450&quot;&gt;⚠ 无写入 API, 仅 mock 种子&lt;/i&gt;&lt;/div&gt;" style="verticalAlign=top;align=center;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="g_db">
          <mxGeometry x="710" y="290" width="240" height="240" as="geometry" />
        </mxCell>

        <!-- digests table -->
        <mxCell id="db_digests" value="&lt;b style=&quot;font-size:13px&quot;&gt;📊 digests&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#999&quot;&gt;日报表 — 每日总结&lt;/span&gt;&lt;hr&gt;&lt;div align=&quot;left&quot; style=&quot;font-size:10px&quot;&gt;&lt;b&gt;PK&lt;/b&gt; id (UUID)&lt;br&gt;&lt;b&gt;FK&lt;/b&gt; user_id → users.id&lt;br&gt;date (Date)&lt;br&gt;score (0~100 生活评分)&lt;br&gt;highlights (JSON — 亮点)&lt;br&gt;problems (JSON — 问题)&lt;br&gt;suggestions (JSON — 建议)&lt;br&gt;trends (JSON — 趋势)&lt;br&gt;created_at&lt;br&gt;&lt;br&gt;&lt;i style=&quot;color:#b85450&quot;&gt;⚠ 无写入 API, 仅 mock 种子&lt;br&gt;(设计预期: AI 汇总当日事件生成)&lt;/i&gt;&lt;/div&gt;" style="verticalAlign=top;align=center;whiteSpace=wrap;html=1;rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="g_db">
          <mxGeometry x="1040" y="290" width="240" height="240" as="geometry" />
        </mxCell>

        <!-- FK relationship legend box -->
        <mxCell id="db_legend" value="&lt;b&gt;表关系 (1:N)&lt;/b&gt;&lt;hr style=&quot;font-size:10px&quot;&gt;&lt;div align=&quot;left&quot; style=&quot;font-size:10px&quot;&gt;users 1:N events&lt;br&gt;users 1:N finance_txns&lt;br&gt;users 1:N insights&lt;br&gt;users 1:N digests&lt;br&gt;&lt;br&gt;子表之间无直接关联&lt;br&gt;events 可间接触发&lt;br&gt;finance_txns 生成&lt;/div&gt;" style="verticalAlign=top;align=center;whiteSpace=wrap;html=1;rounded=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;fontSize=11;" vertex="1" parent="g_db">
          <mxGeometry x="1340" y="50" width="200" height="180" as="geometry" />
        </mxCell>

