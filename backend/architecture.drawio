        <mxCell id="e_mock_db" value="种子数据&#10;INSERT (users/events/&#10;finance/insights/digests)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#999999;strokeWidth=2;endArrow=block;fontSize=9;dashed=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="in_mock" target="g_db">
          <mxGeometry relative="1" as="geometry" />
