        <mxCell id="e_frontend_api" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="in_frontend" target="g_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_voice_in" value="audio" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="in_voice" target="api_voice">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_text_events" value="content" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="in_text" target="api_events">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ==================== EDGES: API → AI ==================== -->
        <mxCell id="e_voice_whisper" value="base64 audio" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="api_voice" target="ai_whisper">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_whisper_intent" value="text" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ai_whisper" target="ai_intent">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
