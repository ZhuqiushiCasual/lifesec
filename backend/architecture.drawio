        <!-- Cross-trigger: event parser detects finance intent → finance parser -->
        <mxCell id="e_event_to_finance" value="detect_finance_intent()=True&#10;自动二次调用" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;fontSize=9;fontStyle=1;labelBackgroundColor=#fff2cc;dashed=1;" edge="1" parent="1" source="ai_event" target="ai_finance">
