        <!-- AI client connections -->
        <mxCell id="e_whisper_client" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d79b00;strokeWidth=1;dashed=1;endArrow=block;" edge="1" parent="1" source="ai_whisper" target="ai_client">
